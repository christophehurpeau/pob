{
  "name": "example-typescript-lib-without-rollup",
  "version": "0.31.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/pob",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pob.git",
    "directory": "pob-examples/typescript-lib-without-rollup"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "node": {
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "yarn clean:build",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet 'pob-examples/typescript-lib-without-rollup'",
    "prepare": "pob-root-postinstall",
    "test": "pnpm run --dir '../..' test -- 'pob-examples/typescript-lib-without-rollup'",
    "watch": "yarn clean:build && rollup --config rollup.config.mjs --watch"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "entries": [
      "index"
    ],
    "rollup": false,
    "typescript": true
  }
}
