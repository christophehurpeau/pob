{
  "name": "example-typescript-lib-rollup-esbuild",
  "version": "0.53.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/pob",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pob.git",
    "directory": "pob-examples/typescript-lib-rollup-esbuild"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index-node22.mjs",
  "module": "./dist/index-browser.es.js",
  "browser": "./dist/index-browser.es.js",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "node": {
        "import": "./dist/index-node22.mjs"
      },
      "browser": {
        "import": "./dist/index-browser.es.js"
      }
    },
    "./run-await": {
      "types": "./src/run-await.ts",
      "node": {
        "import": "./dist/run-await-node22.mjs"
      },
      "browser": {
        "import": "./dist/run-await-browser.es.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs && pnpm run build:definitions",
    "build:definitions": "tsc -p tsconfig.json",
    "clean": "yarn clean:build",
    "clean:build": "pob-esbuild-clean-out dist",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet 'pob-examples/typescript-lib-rollup-esbuild'",
    "test": "pnpm run --dir '../..' test -- 'pob-examples/typescript-lib-rollup-esbuild'",
    "watch": "yarn clean:build && rollup --config rollup.config.mjs --watch"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "workspace:*",
    "@types/node": "24.12.4",
    "typescript": "6.0.3"
  },
  "browserslist": {
    "production": [
      "defaults",
      "> 0.2%",
      "not ie < 12",
      "not safari < 10",
      "not ios_saf < 10"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index",
      "run-await"
    ],
    "envs": [
      {
        "target": "node",
        "version": "22"
      },
      {
        "target": "browser"
      }
    ],
    "typescript": true
  }
}
