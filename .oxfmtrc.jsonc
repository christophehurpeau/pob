{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "sortPackageJson": { "sortScripts": true },
  "ignorePatterns": [
    "/packages/*/dist",
    "/packages/*/build",
    "/@pob/*/dist",
    "/@pob/*/build",
    "/pob-examples/*/dist",
    "/pob-examples/*/build",
    "CHANGELOG.md",
    "**/__fixtures__/**",
  ],
}
