{
  "name": "yarn-version",
  "version": "12.0.0",
  "description": "yarn berry versioning using conventional commits",
  "keywords": [
    "conventional-commits",
    "semantic-release",
    "version",
    "versioning",
    "yarn"
  ],
  "homepage": "https://github.com/christophehurpeau/pob",
  "license": "MIT",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pob.git",
    "directory": "packages/yarn-version"
  },
  "bin": "./bin/yarn-version.mjs",
  "files": [
    "src",
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/index.d.ts",
      "node": {
        "import": "./yarn-version.mjs"
      }
    }
  },
  "scripts": {
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet 'packages/yarn-version'",
    "test": "pnpm run --dir '../..' test -- 'packages/yarn-version'"
  },
  "dependencies": {
    "@pob/version": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.12.4"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {}
}
