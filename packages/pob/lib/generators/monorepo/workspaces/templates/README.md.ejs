<h1 align="center">
  <%= title %>
</h1>
<% if (description) { -%>

<p align="center">
  <%= description %>
</p>
<% } -%>

<h3>📦 Packages</h3>

This repository is a monorepo using workspaces.

| Package | Version | Description |
|---------|---------|-------------|
<% packages.filter(package => !package.name.endsWith('-example')).forEach(package => { -%>
| [<%= package.name %>](<%= (package.repository && package.repository.directory) || (package.name[0] === '@' ? package.name : `packages/${package.name}`) %>) | <% if (!package.private) { -%><a href="https://npmjs.org/package/<%= package.name %>"><img src="https://img.shields.io/npm/v/<%= package.name %>.svg?style=flat-square"></a> <% } -%> | <%= package.description %>
<% }) -%>

<% if (content) { -%>
<%- content %>
<% } -%>
