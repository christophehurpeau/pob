{
  "name": "pob",
  "version": "34.2.0",
  "description": "Pile of bones, library generator with git/babel/typescript/typedoc/readme/jest",
  "keywords": [
    "skeleton"
  ],
  "homepage": "https://github.com/christophehurpeau/pob",
  "bugs": {
    "url": "https://github.com/christophehurpeau/pob/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (http://christophe.hurpeau.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pob.git",
    "directory": "packages/pob"
  },
  "bin": "./lib/pob.js",
  "files": [
    "lib",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "yarn run build:definitions",
    "build:definitions": "tsc -p tsconfig.json",
    "format": "prettier --write",
    "lint": "yarn run lint:eslint",
    "lint:eslint": "yarn '../..' run eslint --quiet 'packages/pob'"
  },
  "dependencies": {
    "@pob/eslint-config": "65.4.3",
    "@pob/eslint-config-typescript-react": "65.4.3",
    "@pob/sort-object": "10.1.2",
    "@pob/sort-pkg": "12.1.2",
    "@types/inquirer": "9.0.9",
    "@yeoman/adapter": "3.1.0",
    "@yeoman/types": "1.8.0",
    "eslint": "10.4.0",
    "findup-sync": "^5.0.0",
    "git-remote-url": "^1.0.1",
    "github-username": "^9.0.0",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "lodash.camelcase": "^4.3.0",
    "lodash.kebabcase": "^4.1.1",
    "mem-fs": "4.1.4",
    "mem-fs-editor": "11.1.4",
    "minimist": "1.2.8",
    "oxfmt": "0.50.0",
    "parse-author": "2.0.0",
    "pob-dependencies": "workspace:*",
    "semver": "7.8.0",
    "typescript": "5.9.3",
    "validate-npm-package-name": "^7.0.0",
    "yeoman-environment": "5.0.0",
    "yeoman-generator": "7.5.1"
  },
  "devDependencies": {
    "@pob/root": "23.2.0",
    "@types/node": "24.12.2"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "typescript": "check-only"
  }
}
