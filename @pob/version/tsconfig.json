{
  "extends": [
    "@pob/root/tsconfigs/strict.json",
    "@pob/root/tsconfigs/targets/rollup-node-24.json"
  ],
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": true,
    "tsBuildInfoFile": "node_modules/.cache/tsc/tsbuildinfo",
    "incremental": true,

    "resolveJsonModule": true,

    "paths": {
      "@pob/rollup-esbuild": ["../../@pob/rollup-esbuild/lib"],
      "@pob/rollup-esbuild/*": ["../../@pob/rollup-esbuild/lib/*"]
    }
  }
}
