{
  "name": "@pob/version",
  "version": "4.1.1",
  "description": "simple versioning using conventional commits",
  "keywords": [
    "bun",
    "conventional-commits",
    "semantic-release",
    "version",
    "versioning",
    "yarn"
  ],
  "homepage": "https://github.com/christophehurpeau/pob",
  "bugs": {
    "url": "https://github.com/christophehurpeau/pob/issues"
  },
  "license": "MIT",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pob.git",
    "directory": "@pob/version"
  },
  "bin": {
    "pob-version": "./dist/index-node.mjs"
  },
  "files": [
    "src",
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index-node.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/index.d.ts",
      "node": {
        "import": "./dist/index-node.mjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs",
    "clean": "pnpm run clean:build",
    "clean:build": "pob-esbuild-clean-out dist",
    "lint": "pnpm run lint:eslint",
    "lint:eslint": "pnpm run --dir '../..' eslint --quiet '@pob/version'",
    "start": "pnpm run clean:build && rollup --config rollup.config.mjs --watch",
    "test": "pnpm run --dir '../..' test -- '@pob/version'",
    "tsc": "tsc"
  },
  "dependencies": {
    "commander": "14.0.3",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "conventional-changelog-preset-loader": "5.0.0",
    "conventional-changelog-writer": "8.4.0",
    "conventional-commits-parser": "6.4.0",
    "nightingale": "18.1.0",
    "semver": "7.8.1"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "workspace:*",
    "@types/node": "24.12.4",
    "@types/semver": "7.7.1",
    "type-fest": "5.6.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true,
        "executable": true
      }
    ],
    "typescript": true
  }
}
