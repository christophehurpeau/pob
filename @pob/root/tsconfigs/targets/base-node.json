{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@pob:target:BaseNode",

  "compilerOptions": {
    "importHelpers": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "types": ["node"]
  }
}
