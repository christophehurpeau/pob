{
  "name": "pob-monorepo",
  "private": true,
  "description": "library generator/tools/scripts",
  "homepage": "https://github.com/christophehurpeau/pob",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": "https://github.com/christophehurpeau/pob.git",
  "workspaces": [
    "packages/*",
    "@pob/*",
    "pob-examples/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs && pnpm run build:definitions",
    "build:definitions": "tsc -b",
    "checks": "node scripts/check-packages.js",
    "clean:build": "pnpm -r --parallel run clean:build",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "lint": "pnpm run format && pnpm run lint:eslint",
    "lint:eslint": "NODE_OPTIONS=--max_old_space_size=4096 eslint --quiet .",
    "prepare": "node @pob/root/bin/pob-root-postinstall.js",
    "test": "TZ=UTC vitest",
    "test:coverage": "TZ=UTC POB_VITEST_COVERAGE=json,text vitest run --coverage",
    "test:coverage:json": "TZ=UTC POB_VITEST_COVERAGE=json vitest run --coverage",
    "test:watch": "TZ=UTC vitest --watch",
    "tsc": "tsc -b",
    "watch": "pnpm run clean:build && rollup --config rollup.config.mjs --watch"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.4.3",
    "@pob/rollup-esbuild": "workspace:*",
    "@pob/root": "workspace:*",
    "@pob/version": "workspace:*",
    "@vitest/coverage-v8": "4.1.7",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.4.0",
    "oxfmt": "0.50.0",
    "react": "19.2.6",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">= 11.0.0"
  }
}
